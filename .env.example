APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# 须与浏览器地址栏主机名、端口一致；用 127.0.0.1 打开时请改为 http://127.0.0.1:8080，否则 Vite 开发资源会跨域失败
APP_URL=http://localhost:8080
APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN

LOG_CHANNEL=stack
# stack 内含通道，逗号分隔；默认 daily 按日切分 storage/logs/laravel-*.log
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# 是否自动记 HTTP 访问（method/path/status/耗时）；未设置时仅 APP_ENV=local 为 true
LOG_HTTP_ACCESS=
LOG_HTTP_ACCESS_CHANNEL=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# 连接表前缀（迁移与 ORM 均使用裸表名，如 users → xdj_users）
DB_TABLE_PREFIX=xdj_

# 后台新增用户未填密码时采用（至少 6 位）。若使用 config:cache，改此后需 php artisan config:clear
DEFAULT_USER_PASSWORD=123456

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"